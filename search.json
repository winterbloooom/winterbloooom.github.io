---
layout: null
permalink: /search.json
sitemap: false
---
[
  {%- for post in site.posts -%}
  {%- assign lv1 = post.categories[0] -%}
  {%- assign catdata = site.data.categories.categories | where: "name", lv1 | first -%}
  {
    "title": {{ post.title | jsonify }},
    "categories": {{ post.categories | join: " · " | jsonify }},
    "slug": {{ catdata.slug | default: "default" | jsonify }},
    "tags": {{ post.tags | join: ", " | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": "{{ post.date | date: '%Y.%m.%d' }}",
    "excerpt": {{ post.excerpt | strip_html | strip_newlines | truncate: 120 | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
